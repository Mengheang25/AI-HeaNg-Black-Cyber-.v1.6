# Environment variables for local development
# Copy to .env and fill in your actual values
# NEVER commit real values to GitHub!

# OpenRouter API Key - Get from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Allowed CORS origins
ALLOWED_ORIGIN=*

# Environment type
NODE_ENV=development

# Optional: Admin email for user management
ADMIN_EMAIL=admin@example.com

# Optional: Database URL if using database
# DATABASE_URL=

# Optional: JWT secret for authentication
# JWT_SECRET=your-secret-key-here

# Optional: Feature flags
ENABLE_SECURITY_LOGS=true
ENABLE_RATE_LIMITING=true
ENABLE_DEV_TOOLS_BLOCKING=true
